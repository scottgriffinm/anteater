{
  "name": "next-anteater",
  "version": "0.3.5",
  "description": "AI-powered live editing for your Next.js app",
  "bin": {
    "anteater": "bin/setup-anteater.mjs",
    "anteater-uninstall": "bin/uninstall-anteater.mjs",
    "next-anteater": "bin/cli.mjs"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "bin/",
    "lib/",
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.8.0"
  },
  "keywords": [
    "anteater",
    "ai",
    "nextjs",
    "github-actions",
    "vercel"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
