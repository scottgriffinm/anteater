# GitHub token with actions:write and contents:write on your repo
GITHUB_TOKEN=

# Shared secret for authenticating AnteaterBar requests
ANTEATER_SECRET=

# GitHub repo in owner/repo format
ANTEATER_GITHUB_REPO=

# Anthropic API key (used in GitHub Actions, not at runtime)
# Set this as a GitHub Actions secret, not here
# ANTHROPIC_API_KEY=
