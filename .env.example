# GitHub personal access token for dispatching workflows and creating PRs.
#
# Fine-grained PAT (recommended):
#   Permissions needed on your repo:
#   - Actions: Read and Write    (dispatch workflows)
#   - Contents: Read and Write   (push branches)
#   - Pull Requests: Read and Write (create/merge PRs)
#
# Classic PAT alternative:
#   Scopes needed: repo, workflow
#
# Generate one at: https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=

# Shared secret for authenticating AnteaterBar requests
ANTEATER_SECRET=

# GitHub repo in owner/repo format
ANTEATER_GITHUB_REPO=

# Anthropic API key (used in GitHub Actions, not at runtime)
# Set this as a GitHub Actions secret, not here:
#   gh secret set ANTHROPIC_API_KEY --repo <owner/repo>
# ANTHROPIC_API_KEY=
